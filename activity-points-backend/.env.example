# Server
PORT=5000

# MongoDB — use MONGO_URI (matches config/db.js)
MONGO_URI=your_mongodb_connection_string

# JWT
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend URL (used for password reset email links)
FRONTEND_URL=http://localhost:5173

# Brevo (Sendinblue) — used for OTP and password reset emails
BREVO_API_KEY=your_brevo_api_key
FROM_EMAIL=noreply@yourcollege.edu
FROM_NAME=Activity Points System

# ImageKit — used for storing certificate files
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Firebase Admin — used for sending push notifications (certificate
# approved/rejected, new certificate uploaded, ticket updates). Paste the
# ENTIRE service account JSON (Firebase Console → Project Settings →
# Service accounts → Generate new private key) as a single-line string.
# Must be the SAME Firebase project as the frontend's VITE_FIREBASE_*
# config, or sends will fail with messaging/mismatched-credential.
FIREBASE_SERVICE_ACCOUNT_JSON=your_full_service_account_json_as_one_line
